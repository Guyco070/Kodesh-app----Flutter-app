  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); [[ \"$f\" == *.dart ]] && { bad=$(awk 'length > 80 {printf \"%d(%d) \", NR, length}' \"$f\" 2>/dev/null); [ -n \"$bad\" ] && echo \"dart format warning: lines over 80 chars at lines: $bad\"; }; exit 0"
